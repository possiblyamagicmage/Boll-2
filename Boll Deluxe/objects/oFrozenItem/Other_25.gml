switch (content) {
	case "coin": {
		image_index=0
	} break;
	
	case "mushroom": {
		image_index=1
	} break;
	
	case "fireflower": {
		image_index=2
	} break;
	
	case "thunderflower": {
		image_index=3
	} break;
    
    case "star": {
        image_index=4
    } break;	
    
    case "1up": {
        image_index=5
    } break;
    
    case "3up": {
        image_index=6
    } break;
	
	case "mysteryorb": {
        image_index=7
    } break;
	
	default: exit;
}